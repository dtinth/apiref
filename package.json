{
  "name": "apiref2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint && vp run test -r && vp run build -r",
    "dev": "vp run website#dev",
    "prepare": "vp config",
    "render": "vp run @apiref/renderer#build && node packages/renderer/dist/cli.mjs fixtures/visual-storyboard.json --out _site --assets-base /assets"
  },
  "devDependencies": {
    "typedoc": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0"
}
