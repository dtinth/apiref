{
  "name": "apiref2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint && vp run test -r && vp run build -r",
    "dev": "vp run website#dev",
    "prepare": "vp config",
    "generate-fixture": "node apps/worker/scripts/generate-fixture.mjs && vp fmt packages/renderer/fixtures",
    "render": "vp run @apiref/renderer#build && node packages/renderer/dist/cli.mjs packages/renderer/fixtures/examples.json --out _site --assets-base /assets",
    "test": "vp test --tags-filter='!slow'",
    "test:slow": "vp test --tags-filter='slow'",
    "test:all": "vp test",
    "check": "vp check"
  },
  "devDependencies": {
    "typedoc": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0"
}
